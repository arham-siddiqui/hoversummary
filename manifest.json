{
  "manifest_version": 3,
  "name": "Hover Summary",
  "version": "0.1.0",
  "description": "Circle any text or image on a webpage and get a plain-language explanation.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>", "http://localhost:11434/*", "http://127.0.0.1:11434/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Summarize an area",
    "default_popup": "popup.html"
  },
  "commands": {
    "start-selection": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Start selecting an area to summarize"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
